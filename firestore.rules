rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Returns the recipient alias data for a given conversation
    function recipientAlias(convId) {
      let conv = get(/databases/$(database)/documents/conversations/$(convId)).data;
      let aliasId = conv.participants[0] == request.auth.uid
        ? conv.participantAliases[1]
        : conv.participantAliases[0];
      return get(/databases/$(database)/documents/aliases/$(aliasId)).data;
    }

    // Recipient alias must be active and must not have blocked the sender
    function canSendMessage(convId) {
      let alias = recipientAlias(convId);
      return alias.isActive == true &&
        (alias.blockedUsers == null || !(request.auth.uid in alias.blockedUsers));
    }

    // Users — sadece kendi profilini okuyabilir/yazabilir
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Aliases — herkes okuyabilir (arama için), sadece sahibi yazabilir
    match /aliases/{aliasId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Conversations — sadece katılımcılar erişebilir
    match /conversations/{convId} {
      // resource == null → document doesn't exist yet (getDoc for getOrCreate check)
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow write: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
    }

    // Messages — sadece ilgili conversation katılımcıları
    match /messages/{msgId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        exists(/databases/$(database)/documents/conversations/$(resource.data.conversationId)) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants
      );
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && canSendMessage(request.resource.data.conversationId);
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deletedAt'])
      );
    }

    // Calls — caller veya callee erişebilir
    match /calls/{callId} {
      allow read, write: if isAuthenticated() && (
        resource.data.callerUserId == request.auth.uid ||
        resource.data.calleeUserId == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.callerUserId == request.auth.uid;

      match /callerCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
      match /calleeCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
    }

    // FCM tokens
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // VoIP push tokens (iOS CallKit)
    match /voipTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // File transfers (P2P signaling only — no file content stored)
    match /fileTransfers/{transferId} {
      allow read, write: if isAuthenticated() && (
        resource == null ||
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.fromUserId == request.auth.uid;

      match /senderIce/{doc} {
        allow read, write: if isAuthenticated();
      }
      match /receiverIce/{doc} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
