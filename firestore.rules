rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users — sadece kendi profilini okuyabilir/yazabilir
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Aliases — herkes okuyabilir (arama için), sadece sahibi yazabilir
    match /aliases/{aliasId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Conversations — sadece katılımcılar erişebilir
    match /conversations/{convId} {
      allow read, write: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
    }

    // Messages — sadece ilgili conversation katılımcıları
    match /messages/{msgId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        exists(/databases/$(database)/documents/conversations/$(resource.data.conversationId)) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants
      );
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deletedAt'])
      );
    }

    // Calls — caller veya callee erişebilir
    match /calls/{callId} {
      allow read, write: if isAuthenticated() && (
        resource.data.callerUserId == request.auth.uid ||
        resource.data.calleeUserId == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.callerUserId == request.auth.uid;

      match /callerCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
      match /calleeCandidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
    }

    // FCM tokens
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // File transfers (P2P signaling only — no file content stored)
    match /fileTransfers/{transferId} {
      allow read, write: if isAuthenticated() && (
        resource == null ||
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.fromUserId == request.auth.uid;

      match /senderIce/{doc} {
        allow read, write: if isAuthenticated();
      }
      match /receiverIce/{doc} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
