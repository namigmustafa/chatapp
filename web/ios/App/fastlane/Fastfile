default_platform(:ios)

platform :ios do
  lane :beta do
    keychain_name = "build.keychain"
    keychain_password = "ci_temp_password"

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      add_to_search_list: true,
    )

    increment_build_number(build_number: ENV["BUILD_NUMBER"])

    import_certificate(
      certificate_path: "distribution.p12",
      certificate_password: ENV["DIST_CERT_PASSWORD"],
      keychain_path: File.expand_path("~/Library/Keychains/#{keychain_name}-db"),
      keychain_password: keychain_password,
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
    )

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "app.chatapp.p2p",
      skip_certificate_verification: true,
      force: true,
      cert_id: "YB52DSFB37",
    )

    require 'xcodeproj'
    xcode_project = Xcodeproj::Project.open('../App.xcodeproj')
    app_target = xcode_project.targets.find { |t| t.name == 'App' }
    app_group = xcode_project.main_group.find_subpath('App', false)
    unless app_group.files.any? { |f| f.path == 'GoogleService-Info.plist' }
      file_ref = app_group.new_file('GoogleService-Info.plist')
      app_target.add_file_references([file_ref])
      xcode_project.save
    end

    # Set entitlements file so push notifications work
    app_target.build_configurations.each do |config|
      config.build_settings['CODE_SIGN_ENTITLEMENTS'] = 'App/App.entitlements'
    end
    xcode_project.save

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: "app.chatapp.p2p",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME],
    )

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "app.chatapp.p2p" => lane_context[SharedValues::SIGH_NAME],
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
